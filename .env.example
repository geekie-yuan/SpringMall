# ===========================================
# Spring Mall 环境变量配置示例
# 复制此文件为 .env 并修改配置
# ===========================================

# 本机 MySQL 数据库配置
DB_USERNAME=root
DB_PASSWORD=QWQ123456

# JWT 配置
# 生产环境请使用更长更安全的随机字符串
JWT_SECRET=dGhpc2lzYXJhbmRvbWtleWZvcmhtYWMyNTZhbGdvcml0aG0xMjM0NTY3ODkw
JWT_EXPIRATION=86400000

# ==================================================
# 支付宝配置 (Alipay Payment Configuration)
# ==================================================
# 支付宝开放平台: https://openhome.alipay.com/
# 沙箱环境说明文档: https://openhome.alipay.com/platform/home.htm

# 应用ID (APP ID from Alipay Open Platform)
# 沙箱环境申请: https://openhome.alipay.com/platform/appManage.htm
ALIPAY_APP_ID=9021000161666558

# 商户私钥 (Your Private Key - RSA2 2048 bits)
# 生成步骤:
# 1. 登录支付宝开放平台开发者中心
# 2. 点击 "应用" -> "开发设置"
# 3. 在 "接口加签方式" 中配置密钥
# 4. 使用 "生成密钥" 工具生成 RSA2 密钥对
# 5. 复制"商户应用私钥"的内容（包含-----BEGIN RSA PRIVATE KEY-----和-----END RSA PRIVATE KEY-----）
ALIPAY_PRIVATE_

# 支付宝公钥 (Alipay Public Key)
# 获取步骤:
# 1. 在支付宝开放平台开发者中心
# 2. 进入你的应用设置页面
# 3. 复制 "支付宝公钥" 的内容
# 注意: 确保已经在支付宝后台上传了商户应用公钥
ALIPAY_PUBLIC_

# 异步通知地址 (Async Notify URL)
# 支付宝服务器将在交易状态变化时调用此地址
# 本地开发: 需要配置内网穿透工具（如 ngrok）使外网可以访问
# 格式: {外网访问地址}/api/v1/payment/alipay/notify
# 示例 (本地开发 + ngrok): https://xxxx.ngrok.io/api/v1/payment/alipay/notify
ALIPAY_NOTIFY_URL=https://anders-unattractable-coinstantaneously.ngrok-free.dev/api/v1/payment/alipay/notify

# 同步返回地址 (Return URL)
# 用户在支付宝网站完成支付后，支付宝会重定向到此地址
# 格式: {前端访问地址}/payment/result
ALIPAY_RETURN_URL=http://localhost:3000/payment/result

# 前端 URL (Frontend Base URL)
# 前端应用的访问地址，用于支付结果页面跳转
FRONTEND_URL=http://localhost:3000
