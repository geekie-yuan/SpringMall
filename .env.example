# ===========================================
# springMall Docker 部署环境变量模板
# 复制此文件: cp .env.example .env.test 或 .env.prod
# ===========================================

# ---- 端口映射（宿主机端口） ----
BACKEND_PORT=25116
FRONTEND_PORT=26115
MYSQL_PORT=3306
REDIS_PORT=6379
RABBITMQ_MGMT_PORT=15672

# ---- 数据库 ----
# Docker Compose 内部通信使用服务名 "mysql"，无需修改
DB_HOST=mysql
DB_PORT=3306
DB_NAME=mall
DB_USERNAME=root
DB_PASSWORD=test123456

# ---- JWT ----
# 生产环境请使用足够长的随机字符串（至少 64 字符，Base64 编码）
JWT_SECRET=your_jwt_secret_base64_encoded

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=test123456

# ---- RabbitMQ ----
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASS=test123456

# ---- 支付宝 ----
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL=
FRONTEND_URL=http://localhost:3000

# ---- Stripe ----
STRIPE_ENABLED=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_REFUND_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
STRIPE_TEST_MODE=true
PRODUCT_IMAGE_BASE_URL=
