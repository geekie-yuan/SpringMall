# ===========================================
# Spring Mall 环境变量配置示例
# 复制此文件为 .env 并修改配置
# ===========================================

# 本机 MySQL 数据库配置
DB_USERNAME=root
DB_PASSWORD=QWQ123456

# JWT 配置
# 生产环境请使用更长更安全的随机字符串
JWT_SECRET=dGhpc2lzYXJhbmRvbWtleWZvcmhtYWMyNTZhbGdvcml0aG0xMjM0NTY3ODkw
JWT_EXPIRATION=86400000

# ==================================================
# 支付宝配置 (Alipay Payment Configuration)
# ==================================================
# 支付宝开放平台: https://openhome.alipay.com/
# 沙箱环境说明文档: https://openhome.alipay.com/platform/home.htm

# 应用ID (APP ID from Alipay Open Platform)
# 沙箱环境申请: https://openhome.alipay.com/platform/appManage.htm
ALIPAY_APP_ID=9021000161666558

# 商户私钥 (Your Private Key - RSA2 2048 bits)
# 生成步骤:
# 1. 登录支付宝开放平台开发者中心
# 2. 点击 "应用" -> "开发设置"
# 3. 在 "接口加签方式" 中配置密钥
# 4. 使用 "生成密钥" 工具生成 RSA2 密钥对
# 5. 复制"商户应用私钥"的内容（包含-----BEGIN RSA PRIVATE KEY-----和-----END RSA PRIVATE KEY-----）
ALIPAY_PRIVATE_

# 支付宝公钥 (Alipay Public Key)
# 获取步骤:
# 1. 在支付宝开放平台开发者中心
# 2. 进入你的应用设置页面
# 3. 复制 "支付宝公钥" 的内容
# 注意: 确保已经在支付宝后台上传了商户应用公钥
ALIPAY_PUBLIC_

# 异步通知地址 (Async Notify URL)
# 支付宝服务器将在交易状态变化时调用此地址
# 本地开发: 需要配置内网穿透工具（如 ngrok）使外网可以访问
# 格式: {外网访问地址}/api/v1/payment/alipay/notify
# 示例 (本地开发 + ngrok): https://xxxx.ngrok.io/api/v1/payment/alipay/notify
ALIPAY_NOTIFY_URL=https://anders-unattractable-coinstantaneously.ngrok-free.dev/api/v1/payment/alipay/notify

# 同步返回地址 (Return URL)
# 用户在支付宝网站完成支付后，支付宝会重定向到此地址
# 格式: {前端访问地址}/payment/result
ALIPAY_RETURN_URL=http://localhost:3000/payment/result

# 前端 URL (Frontend Base URL)
# 前端应用的访问地址，用于支付结果页面跳转
FRONTEND_URL=http://localhost:3000

# ==================================================
# 微信支付配置 (WeChat Pay Configuration)
# ==================================================
# 微信商户平台: https://pay.weixin.qq.com/
# 开发文档: https://pay.weixin.qq.com/wiki/doc/apiv3/index.shtml

# 应用ID (AppID from WeChat Pay Merchant Platform)
# 获取方式: 微信商户平台 -> 产品中心 -> 开发配置 -> 公众号/小程序APPID
WXPAY_APP_ID=wx1234567890

# 商户号 (Merchant ID)
# 获取方式: 微信商户平台 -> 账户中心 -> 商户信息
WXPAY_MCH_ID=1234567890

# APIv3 密钥 (API v3 Key - 32字符)
# 设置方式: 微信商户平台 -> 账户中心 -> API安全 -> 设置APIv3密钥
# 注意: 32位随机字符串，请妥善保管
WXPAY_API_V3_KEY=your-api-v3-key-32-characters

# 商户证书序列号 (Certificate Serial Number)
# 获取方式: 微信商户平台 -> 账户中心 -> API安全 -> 查看证书
# 或使用命令: openssl x509 -in apiclient_cert.pem -noout -serial
WXPAY_SERIAL_NO=your-certificate-serial-number

# 商户私钥 (Merchant Private Key - PEM格式)
# 获取方式: 微信商户平台 -> 账户中心 -> API安全 -> 下载证书
# 将 apiclient_key.pem 文件的完整内容复制到这里
# 注意: 保留 -----BEGIN PRIVATE KEY----- 和 -----END PRIVATE KEY-----
# 多行内容可以用 \n 连接，或者直接在 YAML 中使用多行字符串
WXPAY_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----
MIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQC...
(Your Private Key Content Here - Multiple Lines)
...
-----END PRIVATE KEY-----

# 支付回调URL (Payment Notify URL)
# 微信服务器将在支付成功后调用此地址
# 本地开发需要配置内网穿透工具（如 ngrok）
# 格式: {外网访问地址}/api/v1/payment/wechat/notify
WXPAY_NOTIFY_URL=https://your-domain.com/api/v1/payment/wechat/notify

# 退款回调URL (Refund Notify URL)
# 微信服务器将在退款完成后调用此地址
# 格式: {外网访问地址}/api/v1/payment/wechat/refund/notify
WXPAY_REFUND_NOTIFY_URL=https://your-domain.com/api/v1/payment/wechat/refund/notify

# ==================================================
# Stripe 支付配置 (Stripe Payment Configuration)
# ==================================================
# Stripe Dashboard: https://dashboard.stripe.com/
# 开发文档: https://docs.stripe.com/

# 是否启用 Stripe 支付 (Enable Stripe Payment)
STRIPE_ENABLED=true

# Secret Key (服务端密钥 - 用于 API 调用)
# 获取方式: Stripe Dashboard -> Developers -> API keys
# 测试环境: sk_test_xxx, 生产环境: sk_live_xxx
# ⚠️ 请替换为您自己的 Stripe Secret Key,绝不提交真实密钥到版本控制!
STRIPE_SECRET_KEY=sk_test_PLACEHOLDER_REPLACE_WITH_YOUR_KEY

# Webhook 签名密钥 (Webhook Signing Secret)
# 获取方式: Stripe Dashboard -> Developers -> Webhooks -> Add endpoint
# 监听事件: checkout.session.completed, checkout.session.expired
# 端点 URL: https://your-domain.com/api/v1/payment/stripe/webhook
# ⚠️ 请替换为您在 Stripe Dashboard 配置 Webhook 后生成的 Signing Secret
STRIPE_WEBHOOK_SECRET=whsec_PLACEHOLDER_REPLACE_WITH_YOUR_SECRET

# 退款 Webhook 签名密钥 (Refund Webhook Signing Secret)
# 端点 URL: https://your-domain.com/api/v1/payment/stripe/refund/webhook
# 监听事件: charge.refunded
# ⚠️ 请替换为您在 Stripe Dashboard 配置退款 Webhook 后生成的 Signing Secret
STRIPE_REFUND_WEBHOOK_SECRET=whsec_PLACEHOLDER_REPLACE_WITH_YOUR_SECRET

# Checkout Session 成功返回地址 (Checkout Success URL)
# 用户支付成功后跳转的前端页面地址 (会自动追加 ?paymentNo=xxx 参数)
STRIPE_SUCCESS_URL=http://localhost:3000/payment/stripe/result

# Checkout Session 取消返回地址 (Checkout Cancel URL)
# 用户取消支付后跳转的前端页面地址 (支持 {ORDER_NO} 占位符)
STRIPE_CANCEL_URL=http://localhost:3000/payment/{ORDER_NO}

# 测试模式 (Test Mode)
# true: 使用测试密钥, false: 使用生产密钥
STRIPE_TEST_MODE=true
